<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ParaTool.App.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />

        <!-- Force ScrollViewer to always show full-size scrollbars (no auto-hide/minimal mode) -->
        <Style Selector="ScrollViewer">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>

        <!-- Thick scrollbar: override FluentTheme sizing for all states -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="14" />
            <Setter Property="MinWidth" Value="14" />
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}" />
        </Style>
        <Style Selector="ScrollBar:vertical /template/ Thumb">
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
        <Style Selector="ScrollBar:vertical /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="14" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}" />
        </Style>
        <Style Selector="ScrollBar:horizontal /template/ Thumb">
            <Setter Property="MinHeight" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
        <Style Selector="ScrollBar:horizontal /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
        </Style>
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Themes/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Default font sizes (scale 1.0); updated at runtime by MainWindow -->
            <x:Double x:Key="FontSize10">10</x:Double>
            <x:Double x:Key="FontSize11">11</x:Double>
            <x:Double x:Key="FontSize12">12</x:Double>
            <x:Double x:Key="FontSize13">13</x:Double>
            <x:Double x:Key="FontSize14">14</x:Double>
            <x:Double x:Key="FontSize16">16</x:Double>
            <x:Double x:Key="FontSize18">18</x:Double>
            <x:Double x:Key="FontSize20">20</x:Double>
            <x:Double x:Key="FontSize22">22</x:Double>
            <x:Double x:Key="FontSize24">24</x:Double>
            <x:Double x:Key="DefaultFontSize">14</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
