<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ParaTool.App.ViewModels"
             xmlns:loc="using:ParaTool.App.Localization"
             x:Class="ParaTool.App.Views.ScanningView"
             x:DataType="vm:ScanningViewModel">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" MinWidth="400">
        <TextBlock Text="{Binding PleaseWait, Source={x:Static loc:Loc.Instance}}"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{StaticResource GoldBrush}"
                   HorizontalAlignment="Center" />

        <!-- Stage text -->
        <TextBlock Text="{Binding StageText}"
                   FontSize="14"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" />

        <!-- Progress bar -->
        <Border Background="{StaticResource CardBgBrush}"
                CornerRadius="6"
                Padding="4"
                Margin="20,8">
            <Grid>
                <ProgressBar Value="{Binding Percent}"
                             Minimum="0" Maximum="100"
                             Height="20"
                             CornerRadius="4"
                             Foreground="{StaticResource AccentBrush}"
                             Background="Transparent" />
                <TextBlock Text="{Binding Percent, StringFormat={}{0}%}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Stats -->
        <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding ModsScanned, Source={x:Static loc:Loc.Instance}}"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                <TextBlock Text="{Binding ScannedPaks}"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding ModsSelected, Source={x:Static loc:Loc.Instance}}"
                           Foreground="{StaticResource SuccessBrush}" FontSize="14" />
                <TextBlock Text="{Binding ModsFound}"
                           Foreground="{StaticResource SuccessBrush}" FontSize="14" FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
    </StackPanel>

</UserControl>
