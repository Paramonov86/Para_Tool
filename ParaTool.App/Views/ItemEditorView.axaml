<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ParaTool.App.ViewModels"
             xmlns:loc="using:ParaTool.App.Localization"
             xmlns:conv="using:ParaTool.App.Converters"
             x:Class="ParaTool.App.Views.ItemEditorView"
             x:DataType="vm:ItemEditorViewModel">

    <UserControl.Resources>
        <conv:ExpandArrowConverter x:Key="ExpandConv" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12" Spacing="2">
            <TextBlock Text="{Binding IntegratorTitle, Source={x:Static loc:Loc.Instance}}"
                       FontSize="{DynamicResource FontSize24}" FontWeight="Bold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EditorTitle, Source={x:Static loc:Loc.Instance}}"
                       FontSize="{DynamicResource FontSize14}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="*,300">

            <!-- Left: Mod list -->
            <Border Grid.Column="0" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- All mods row -->
                    <Border Grid.Row="0"
                            Background="{StaticResource CardBgBrush}"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding AllEnabled}"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AllMods, Source={x:Static loc:Loc.Instance}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AllModsCount}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Sort bar -->
                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBgBrush}"
                            CornerRadius="6"
                            Padding="8,4"
                            Margin="0,0,0,4"
                            BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="{Binding SortByName, Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding SetSortCommand}" CommandParameter="Name"
                                    FontSize="{DynamicResource FontSize11}" Padding="8,3" CornerRadius="4"
                                    BorderThickness="0"
                                    Name="SortNameBtn" />
                            <Button Content="{Binding SortByRarity, Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding SetSortCommand}" CommandParameter="Rarity"
                                    FontSize="{DynamicResource FontSize11}" Padding="8,3" CornerRadius="4"
                                    BorderThickness="0"
                                    Name="SortRarityBtn" />
                            <Button Content="{Binding SortByTheme, Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding SetSortCommand}" CommandParameter="Theme"
                                    FontSize="{DynamicResource FontSize11}" Padding="8,3" CornerRadius="4"
                                    BorderThickness="0"
                                    Name="SortThemeBtn" />
                            <Button Content="{Binding SortBySlot, Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding SetSortCommand}" CommandParameter="Slot"
                                    FontSize="{DynamicResource FontSize11}" Padding="8,3" CornerRadius="4"
                                    BorderThickness="0"
                                    Name="SortSlotBtn" />
                            <Button Command="{Binding ToggleSortDirectionCommand}"
                                    FontSize="{DynamicResource FontSize13}" Padding="6,2" CornerRadius="4"
                                    Background="{StaticResource CardBgBrush}"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    BorderThickness="0"
                                    Name="SortDirBtn" />
                        </StackPanel>
                    </Border>

                    <!-- Mod list with scroll -->
                    <ScrollViewer Grid.Row="2" Name="ModListScroll">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ModVM">
                                    <Border Background="{Binding ModBackground}"
                                            CornerRadius="4"
                                            Padding="12,6"
                                            Margin="0,2">
                                        <StackPanel>
                                            <!-- Mod header row -->
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding Enabled}"
                                                          Margin="0,0,8,0" />
                                                <!-- Expand arrow -->
                                                <Button Grid.Column="1"
                                                        Content="{Binding IsExpanded, Converter={StaticResource ExpandConv}}"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource AccentLightBrush}"
                                                        BorderThickness="0"
                                                        Padding="6,2"
                                                        FontSize="{DynamicResource FontSize16}"
                                                        FontWeight="Bold"
                                                        MinWidth="28"
                                                        Name="ExpandBtn"
                                                        Tag="{Binding}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="4,0" />
                                                <!-- Mod-level theme button -->
                                                <Button Grid.Column="3"
                                                        Content="{Binding ThemesLabel, Source={x:Static loc:Loc.Instance}}"
                                                        FontSize="{DynamicResource FontSize10}"
                                                        Padding="6,2"
                                                        Margin="4,0"
                                                        Background="{StaticResource HoverBgBrush}"
                                                        Foreground="{StaticResource TextMutedBrush}"
                                                        BorderThickness="0"
                                                        CornerRadius="4"
                                                        Name="ModThemeBtn"
                                                        Tag="{Binding}" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding CountDisplay}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0" />
                                            </Grid>

                                            <!-- Expanded items -->
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          IsVisible="{Binding IsExpanded}"
                                                          Margin="28,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:ItemVM">
                                                        <Border CornerRadius="4"
                                                                Padding="8,4"
                                                                Margin="0,1"
                                                                Background="{StaticResource CardBgBrush}"
                                                                BorderBrush="{Binding RarityColor}"
                                                                BorderThickness="0,0,3,0">
                                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding Enabled}"
                                                                          Margin="0,0,6,0" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding ItemLabel}"
                                                                           Foreground="{Binding ItemLabelForeground}"
                                                                           FontWeight="{Binding HasDisplayName, Converter={x:Static conv:BoolToFontWeightConverter.Instance}}"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           FontSize="{DynamicResource FontSize12}"
                                                                           ToolTip.Tip="{Binding StatId}" />
                                                                <!-- Pool selector -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{x:Static vm:ItemVM.PoolOptions}"
                                                                          SelectedItem="{Binding SelectedPool}"
                                                                          FontSize="{DynamicResource FontSize11}"
                                                                          MinWidth="110"
                                                                          Margin="4,0"
                                                                          Padding="6,3">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:LabeledOption">
                                                                            <TextBlock Text="{Binding Display}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                                <!-- Rarity selector -->
                                                                <ComboBox Grid.Column="3"
                                                                          ItemsSource="{x:Static vm:ItemVM.RarityOptions}"
                                                                          SelectedItem="{Binding SelectedRarity}"
                                                                          Foreground="{Binding RarityColor}"
                                                                          FontSize="{DynamicResource FontSize11}"
                                                                          FontWeight="SemiBold"
                                                                          MinWidth="110"
                                                                          Margin="4,0"
                                                                          Padding="6,3"
                                                                          BorderBrush="{Binding RarityColor}"
                                                                          BorderThickness="1.5">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:LabeledOption">
                                                                            <TextBlock Text="{Binding Display}" />
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                                <!-- Theme selector button -->
                                                                <Button Grid.Column="4"
                                                                        Content="{Binding ThemesDisplay}"
                                                                        FontSize="{DynamicResource FontSize10}"
                                                                        MinWidth="80"
                                                                        Padding="6,3"
                                                                        Margin="4,0"
                                                                        Background="{StaticResource HoverBgBrush}"
                                                                        Foreground="{StaticResource TextMutedBrush}"
                                                                        BorderThickness="0"
                                                                        CornerRadius="4"
                                                                        Name="ThemeBtn"
                                                                        Tag="{Binding}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Info panel (scrollable) -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="12">
                    <!-- Profile bar -->
                    <Border Background="{StaticResource PanelBgBrush}"
                            CornerRadius="6"
                            Padding="12,8"
                            BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding ProfileLabel, Source={x:Static loc:Loc.Instance}}"
                                       FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <!-- Existing profiles dropdown -->
                            <ComboBox ItemsSource="{Binding ProfileNames}"
                                      SelectedItem="{Binding SelectedProfile}"
                                      FontSize="{DynamicResource FontSize12}"
                                      HorizontalAlignment="Stretch" />
                            <!-- New profile name input -->
                            <TextBox Text="{Binding NewProfileName}"
                                     Watermark="{Binding ProfileNewName, Source={x:Static loc:Loc.Instance}}"
                                     FontSize="{DynamicResource FontSize12}"
                                     HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="{Binding ProfileSave, Source={x:Static loc:Loc.Instance}}"
                                        Command="{Binding SaveProfileCommand}"
                                        FontSize="{DynamicResource FontSize11}" Padding="10,4"
                                        Background="{StaticResource AccentBrush}"
                                        Foreground="White"
                                        CornerRadius="4" />
                                <Button Content="{Binding ProfileDelete, Source={x:Static loc:Loc.Instance}}"
                                        Command="{Binding DeleteProfileCommand}"
                                        FontSize="{DynamicResource FontSize11}" Padding="10,4"
                                        Background="#33E74C5B"
                                        Foreground="{DynamicResource ErrorBrush}"
                                        CornerRadius="4" />
                            </StackPanel>
                            <!-- Toast notification -->
                            <Border IsVisible="{Binding ShowProfileToast}"
                                    Background="#1A2ECC71"
                                    BorderBrush="{DynamicResource SuccessBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,4">
                                <TextBlock Text="{Binding ProfileToastText}"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="{DynamicResource FontSize11}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Missing items warning -->
                    <Border IsVisible="{Binding HasMissingItems}"
                            Background="#33F39C12"
                            BorderBrush="{DynamicResource WarningBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding MissingItemsText}"
                                       Foreground="{DynamicResource WarningBrush}"
                                       FontSize="{DynamicResource FontSize11}"
                                       TextWrapping="Wrap" />
                            <Button Grid.Column="1"
                                    Content="{Binding MissingItemsDismiss, Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding DismissMissingItemsCommand}"
                                    FontSize="{DynamicResource FontSize10}" Padding="6,2"
                                    Background="Transparent"
                                    Foreground="{DynamicResource WarningBrush}"
                                    BorderThickness="0"
                                    VerticalAlignment="Top" />
                        </Grid>
                    </Border>

                    <!-- Info badge -->
                    <Border Background="{StaticResource AccentBrush}"
                            CornerRadius="6"
                            Padding="12,8">
                        <TextBlock Text="{Binding ModsCountText}"
                                   Foreground="White"
                                   FontSize="{DynamicResource FontSize12}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <!-- Instructions -->
                    <Border Background="{StaticResource PanelBgBrush}"
                            CornerRadius="6"
                            Padding="16,12"
                            BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding Instructions, Source={x:Static loc:Loc.Instance}}"
                                       FontSize="{DynamicResource FontSize16}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding InstructionStep1, Source={x:Static loc:Loc.Instance}}"
                                       TextWrapping="Wrap" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding InstructionStep2, Source={x:Static loc:Loc.Instance}}"
                                       TextWrapping="Wrap" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding InstructionStep3, Source={x:Static loc:Loc.Instance}}"
                                       TextWrapping="Wrap" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding InstructionStep4, Source={x:Static loc:Loc.Instance}}"
                                       TextWrapping="Wrap" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Theme selector popup (shown when ThemeBtn/ModThemeBtn clicked) -->
                    <Border Name="ThemePopup"
                            Background="{StaticResource PanelBgBrush}"
                            CornerRadius="6"
                            Padding="12,8"
                            BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1"
                            IsVisible="False">
                        <StackPanel Spacing="4">
                            <TextBlock Name="ThemePopupTitle"
                                       FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
                            <ItemsControl Name="ThemeCheckboxes" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Bottom: Patch button / Progress + Discord -->
        <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="*,Auto">
            <Panel Grid.Column="0" HorizontalAlignment="Right">
                <!-- Patch + Restore row -->
                <StackPanel Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding ShowPatchButton}">
                    <!-- Restore AMP button (undo icon) -->
                    <Button IsVisible="{Binding ShowRestoreButton}"
                            Command="{Binding RestoreAmpCommand}"
                            ToolTip.Tip="{Binding RestoreAmpTooltip, Source={x:Static loc:Loc.Instance}}"
                            Background="#1A2ECC71"
                            BorderBrush="{DynamicResource SuccessBrush}"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Padding="10,10"
                            VerticalAlignment="Center"
                            Cursor="Hand">
                        <Path Fill="#2ECC71"
                              Data="M12.5 8c-2.65 0-5.05 1.04-6.83 2.73L2.5 7.56v7.17h7.17l-3.13-3.13C7.98 10.19 10.07 9.25 12.5 9.25c3.58 0 6.61 2.35 7.63 5.58l1.24-.4C20.15 10.79 16.64 8 12.5 8z"
                              Stretch="Uniform"
                              Width="22" Height="22" />
                    </Button>

                    <!-- Patch button -->
                    <Button Content="{Binding PatchButton, Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding PatchCommand}"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            FontSize="{DynamicResource FontSize18}" FontWeight="Bold"
                            Padding="40,12"
                            CornerRadius="8" />
                </StackPanel>

                <!-- Progress bar -->
                <Border IsVisible="{Binding IsPatching}"
                        Background="{StaticResource CardBgBrush}"
                        CornerRadius="8"
                        Padding="20,12"
                        MinWidth="300"
                        HorizontalAlignment="Right">
                    <Grid RowDefinitions="Auto,Auto">
                        <ProgressBar Value="{Binding PatchPercent}"
                                     Minimum="0" Maximum="100"
                                     Height="24"
                                     CornerRadius="4"
                                     Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding PatchStatus}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="{DynamicResource FontSize11}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </Grid>
                </Border>

                <!-- Success indicator -->
                <Border IsVisible="{Binding PatchSuccess}"
                        Background="#1A2ECC71"
                        BorderBrush="{DynamicResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,12"
                        HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x2705;"
                                   FontSize="{DynamicResource FontSize18}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PatchSuccessMessage}"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="{DynamicResource FontSize14}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Error indicator -->
                <Border IsVisible="{Binding PatchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#1A2ECC71"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,12"
                        HorizontalAlignment="Right">
                    <TextBlock Text="{Binding PatchStatus}"
                               Foreground="{DynamicResource ErrorBrush}"
                               FontSize="{DynamicResource FontSize13}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               MaxWidth="400" />
                </Border>
            </Panel>

            <!-- Discord icon -->
            <Button Grid.Column="1" Margin="12,0,0,0"
                    Name="DiscordBtn"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Image Source="/Assets/discord_icon.png"
                       Width="80" Height="80" />
            </Button>
        </Grid>
    </Grid>

</UserControl>
