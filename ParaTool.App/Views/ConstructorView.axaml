<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ParaTool.App.ViewModels"
             xmlns:loc="using:ParaTool.App.Localization"
             xmlns:ctrl="using:ParaTool.App.Controls"
             x:Class="ParaTool.App.Views.ConstructorView"
             x:DataType="vm:ConstructorViewModel">

    <Panel>
    <Grid ColumnDefinitions="250*,Auto,500*,Auto,350*" Margin="16,8">

        <!-- ═══════ LEFT: NAVIGATOR ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}"
                CornerRadius="8" MinWidth="180"
                BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Row="0"
                           Text="{Binding NavTitle, Source={x:Static loc:Loc.Instance}}"
                           FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,6" LetterSpacing="2" />
                <TextBox Grid.Row="1" Text="{Binding SearchText}"
                         Watermark="{Binding NavSearch, Source={x:Static loc:Loc.Instance}}"
                         FontSize="{DynamicResource FontSize12}" Margin="8,0,8,4" Padding="8,6" CornerRadius="6"
                         Background="{StaticResource InputBgBrush}" />

                <!-- Sort bar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,4" Spacing="2"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Button Content="{Binding SortByName, Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding SetSortCommand}" CommandParameter="Name"
                            FontSize="{DynamicResource FontSize10}" Padding="6,2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" />
                    <Button Content="{Binding SortByRarity, Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding SetSortCommand}" CommandParameter="Rarity"
                            FontSize="{DynamicResource FontSize10}" Padding="6,2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" />
                    <Button Content="{Binding SortBySlot, Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding SetSortCommand}" CommandParameter="Slot"
                            FontSize="{DynamicResource FontSize10}" Padding="6,2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand" />
                    <Button Command="{Binding ToggleSortDirectionCommand}"
                            FontSize="{DynamicResource FontSize10}" Padding="6,2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Content="↕" />
                </StackPanel>

                <!-- Saved artifacts -->
                <StackPanel Grid.Row="3" IsVisible="{Binding HasSavedArtifacts}">
                    <TextBlock Text="{Binding NavMyItems, Source={x:Static loc:Loc.Instance}}"
                               FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentLightBrush}"
                               Margin="12,4,8,4" LetterSpacing="1" />
                    <ItemsControl ItemsSource="{Binding SavedArtifacts}" Margin="4,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ArtifactItemVM">
                                <Button Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Padding="0" Margin="0,1" Cursor="Hand"
                                        Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).SelectSavedArtifactCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding NavDuplicate, Source={x:Static loc:Loc.Instance}}"
                                                      Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).DuplicateArtifactCommand}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="{Binding NavDelete, Source={x:Static loc:Loc.Instance}}"
                                                      Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).DeleteArtifactCommand}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Border Padding="10,8" CornerRadius="6"
                                            BorderThickness="0,0,3,0" BorderBrush="{Binding RarityColor}"
                                            Background="{Binding SelectionBackground}">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <TextBlock Text="{Binding DisplayLabel}" FontSize="{DynamicResource FontSize13}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Text="{Binding EditStatId}" FontSize="{DynamicResource FontSize10}"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="8,6" />
                </StackPanel>

                <!-- Items: grouped when no search, flat when searching -->
                <ScrollViewer Grid.Row="4">
                    <StackPanel>
                        <!-- Grouped view (no search) -->
                        <ItemsControl ItemsSource="{Binding NavGroups}" Margin="4,0"
                                      IsVisible="{Binding IsNotSearching}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:NavGroupVM">
                                    <StackPanel Margin="0,0,0,2">
                                        <!-- Group header -->
                                        <Button Background="{Binding HeaderBackground}" BorderThickness="0"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                Padding="10,8" Cursor="Hand" CornerRadius="6"
                                                Name="NavGroupToggle" Tag="{Binding}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Text="▸"
                                                           FontSize="{DynamicResource FontSize12}" Foreground="{StaticResource AccentLightBrush}"
                                                           VerticalAlignment="Center" Width="16" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="{DynamicResource FontSize13}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Name}" />
                                                <Border Grid.Column="2" Background="{StaticResource CardBgBrush}"
                                                        CornerRadius="8" Padding="6,2" Margin="6,0,0,0">
                                                    <TextBlock Text="{Binding Count}"
                                                               FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Button>
                                        <!-- Group items -->
                                        <ItemsControl ItemsSource="{Binding Items}"
                                                      IsVisible="{Binding IsExpanded}" Margin="0,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:BaseItemVM">
                                                    <Button Background="Transparent" BorderThickness="0"
                                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                            Padding="0" Margin="0,2" Cursor="Hand"
                                                            Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).OpenBaseItemCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Border Padding="10,7" CornerRadius="6"
                                                                BorderThickness="3,0,0,0"
                                                                BorderBrush="{Binding RarityColor}"
                                                                Background="{StaticResource InputBgBrush}">
                                                            <TextBlock Text="{Binding Label}" FontSize="{DynamicResource FontSize12}"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       ToolTip.Tip="{Binding FullLabel}" />
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Flat filtered view (when searching) -->
                        <ItemsControl ItemsSource="{Binding FilteredBaseItems}" Margin="4,0"
                                      IsVisible="{Binding IsSearching}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BaseItemVM">
                                    <Button Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Padding="0" Margin="0,2" Cursor="Hand"
                                            Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).OpenBaseItemCommand}"
                                            CommandParameter="{Binding}">
                                        <Border Padding="10,7" CornerRadius="6"
                                                BorderThickness="3,0,0,0"
                                                BorderBrush="{Binding RarityColor}"
                                                Background="{StaticResource InputBgBrush}">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <TextBlock Text="{Binding Label}" FontSize="{DynamicResource FontSize12}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           ToolTip.Tip="{Binding FullLabel}" />
                                                <TextBlock Grid.Row="1" Text="{Binding ModName}" FontSize="{DynamicResource FontSize10}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,2,0,0" />
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Support link -->
                <Border Grid.Row="5" Background="{StaticResource CardBgBrush}"
                        CornerRadius="6" Padding="8,6" Margin="8,6,8,8">
                    <Button Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0" Cursor="Hand"
                            Name="BoostyLink">
                        <TextBlock FontSize="{DynamicResource FontSize10}" TextAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="{Binding LblMadeWith, Source={x:Static loc:Loc.Instance}}" /><Run Text="&#x2764;" Foreground="{DynamicResource ErrorBrush}" /><Run Text="{Binding LblSupportTool, Source={x:Static loc:Loc.Instance}}" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" TextDecorations="Underline" />
                        </TextBlock>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="6" Background="Transparent" ResizeDirection="Columns" />

        <!-- ═══════ CENTER: EDITOR ═══════ -->
        <Border Grid.Column="2" Background="{StaticResource PanelBgBrush}"
                CornerRadius="8" MinWidth="300"
                BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0"
                           Text="{Binding ConstructorEditorTitle, Source={x:Static loc:Loc.Instance}}"
                           FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,6" LetterSpacing="2" />

                <StackPanel Grid.Row="1" IsVisible="{Binding HasNoSelection}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12">
                    <TextBlock Text="&#x1F4E6;" FontSize="40"
                               HorizontalAlignment="Center" Opacity="0.3" />
                    <TextBlock Text="{Binding EditorNoSelection, Source={x:Static loc:Loc.Instance}}"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="{DynamicResource FontSize14}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" Opacity="0.5"
                               LineHeight="22" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" IsVisible="{Binding IsArtifactSelected}" Margin="8,4,8,8">
                    <StackPanel Spacing="12" DataContext="{Binding SelectedArtifact}">
                        <!-- Rarity -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding FieldRarity, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <WrapPanel Name="RarityChips" />
                            </StackPanel>
                        </Border>
                        <!-- Slot -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ChipSlot, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <WrapPanel Name="PoolChips" />
                            </StackPanel>
                        </Border>
                        <!-- Themes -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ChipThemes, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <WrapPanel Name="ThemeChips" />
                            </StackPanel>
                        </Border>
                        <!-- Armor properties -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12"
                                IsVisible="{Binding IsArmor}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding LblArmor, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Text="{Binding LblArmorClass, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                               IsVisible="{Binding ShowArmorClass}" />
                                    <ctrl:TumblerChipEditor Grid.Column="1" Text="{Binding EditArmorClass}"
                                                           Step="1" MinValue="0" MaxValue="30"
                                                           IsVisible="{Binding ShowArmorClass}"
                                                           HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="1" Text="{Binding LblArmorType, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:TumblerChipEditor Grid.Row="1" Grid.Column="1" Text="{Binding EditArmorType}"
                                                           Items="{x:Static vm:ArtifactItemVM.ArmorTypeOptions}"
                                                           Margin="0,6,0,0" HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="2" Text="{Binding LblProficiency, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:TumblerChipEditor Grid.Row="2" Grid.Column="1" Text="{Binding EditProficiencyGroup}"
                                                           Items="{x:Static vm:ArtifactItemVM.ProficiencyOptions}"
                                                           Margin="0,6,0,0" HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="3" Text="{Binding LblWeight, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:TumblerChipEditor Grid.Row="3" Grid.Column="1" Text="{Binding EditWeight}"
                                                           Step="0.01" Margin="0,6,0,0" HorizontalAlignment="Left" />

                                </Grid>
                                <CheckBox Content="{Binding LblUnique, Source={x:Static loc:Loc.Instance}}" Foreground="{DynamicResource WarningBrush}"
                                          IsChecked="{Binding EditUnique}" FontSize="{DynamicResource FontSize12}"
                                          ToolTip.Tip="{Binding TipUnique, Source={x:Static loc:Loc.Instance}}"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Weapon properties -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12"
                                IsVisible="{Binding IsWeapon}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding LblWeapon, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Text="{Binding LblDamage, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding EditDamage}" Watermark="1d8"
                                             FontSize="{DynamicResource FontSize12}" Padding="8,4" Background="{StaticResource InputBgBrush}" CornerRadius="4" />

                                    <TextBlock Grid.Row="1" Text="{Binding LblVersatile, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditVersatileDamage}" Watermark="1d10"
                                             FontSize="{DynamicResource FontSize12}" Padding="8,4" Margin="0,6,0,0" Background="{StaticResource InputBgBrush}" CornerRadius="4" />

                                    <TextBlock Grid.Row="2" Text="{Binding LblDefaultBoosts, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:BoostBlocksEditor Grid.Row="2" Grid.Column="1" Text="{Binding EditDefaultBoosts}" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="3" Text="{Binding LblProperties, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:ToggleChipsEditor Grid.Row="3" Grid.Column="1" Text="{Binding EditWeaponProperties}"
                                                                    Options="{x:Static vm:ArtifactItemVM.WeaponPropertyOptions}" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="4" Text="{Binding LblBoostsMainHand, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:BoostBlocksEditor Grid.Row="4" Grid.Column="1" Text="{Binding EditBoostsOnEquipMainHand}" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="5" Text="{Binding LblBoostsOffHand, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:BoostBlocksEditor Grid.Row="5" Grid.Column="1" Text="{Binding EditBoostsOnEquipOffHand}" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="6" Text="{Binding LblWeight, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0" />
                                    <ctrl:TumblerChipEditor Grid.Row="6" Grid.Column="1" Text="{Binding EditWeight}"
                                                           Step="0.01" Margin="0,6,0,0" HorizontalAlignment="Left" />

                                </Grid>
                                <CheckBox Content="{Binding LblUnique, Source={x:Static loc:Loc.Instance}}" Foreground="{DynamicResource WarningBrush}"
                                          IsChecked="{Binding EditUnique}" FontSize="{DynamicResource FontSize12}"
                                          ToolTip.Tip="{Binding TipUnique, Source={x:Static loc:Loc.Instance}}"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Icon selector -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding LblIcon, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <!-- Browse existing -->
                                    <Button Command="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).OpenIconBrowserCommand}"
                                            Background="{StaticResource InputBgBrush}"
                                            BorderThickness="0" CornerRadius="6"
                                            Padding="8,6" Cursor="Hand"
                                            HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Width="32" Height="32" CornerRadius="4" ClipToBounds="True"
                                                    IsVisible="{Binding HasIcon}">
                                                <Image Source="{Binding IconBitmap}" Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Text="{Binding Artifact.AtlasIconMapKey, FallbackValue='Browse icons...'}"
                                                       FontSize="{DynamicResource FontSize12}" Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <!-- Upload custom -->
                                    <Button Grid.Column="1" Margin="6,0,0,0" Name="UploadPngBtn"
                                            Background="{StaticResource CardBgBrush}"
                                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                                            CornerRadius="6" Padding="12,6" Cursor="Hand"
                                            ToolTip.Tip="{Binding TipUploadPng, Source={x:Static loc:Loc.Instance}}">
                                        <TextBlock Text="{Binding LblUploadPng, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Mechanics -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding CardMechanics, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1"
                                           ToolTip.Tip="{Binding LblCardMechanics, Source={x:Static loc:Loc.Instance}}" />
                                <TextBlock Text="{Binding LblBoosts, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" />
                                <ctrl:BoostBlocksEditor Text="{Binding EditBoosts}" />
                                <TextBlock Text="{Binding LblStatuses, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" />
                                <ctrl:ChipListEditor Text="{Binding EditStatusOnEquip}" ChipColor="#E67E22"
                                                      SearchItems="{ReflectionBinding DataContext.AllStatuses, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <TextBlock Text="{Binding LblSpells, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" />
                                <ctrl:ChipListEditor Text="{Binding EditSpellsOnEquip}" ChipColor="#9B59B6"
                                                      SearchItems="{ReflectionBinding DataContext.AllSpells, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                        </Border>
                        <!-- Passives -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12"
                                ClipToBounds="False">
                            <StackPanel Spacing="6" ClipToBounds="False">
                                <TextBlock Text="{Binding LblPassives, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                    <ctrl:SearchPickerChip Name="PassivePickerChip"
                                        Items="{Binding $parent[UserControl].((vm:ConstructorViewModel)DataContext).AllPassives}"
                                        Watermark="{Binding WmSearchPassive, Source={x:Static loc:Loc.Instance}}" />
                                    <Button Name="AddPassiveBtn"
                                            Background="{StaticResource InputBgBrush}"
                                            Foreground="{StaticResource AccentLightBrush}"
                                            FontSize="{DynamicResource FontSize16}" FontWeight="Bold"
                                            Content="+" Padding="6,0" CornerRadius="12"
                                            BorderThickness="0" Cursor="Hand"
                                            ToolTip.Tip="{Binding LblAddEmptyPassive, Source={x:Static loc:Loc.Instance}}" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding PassiveVMs}" ClipToBounds="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PassiveVM">
                                            <Border Background="{StaticResource InputBgBrush}" CornerRadius="4"
                                                    Padding="8,6" Margin="0,2" ClipToBounds="False">
                                                <StackPanel Spacing="4" ClipToBounds="False">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Button Background="Transparent" BorderThickness="0"
                                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                                Padding="0" Cursor="Hand" Name="PassiveToggleBtn" Tag="{Binding}">
                                                            <Grid ColumnDefinitions="Auto,*">
                                                                <TextBlock Text="▸" FontSize="{DynamicResource FontSize12}" Foreground="{StaticResource AccentLightBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0" Width="12" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource GoldBrush}"
                                                                           ToolTip.Tip="{Binding StatName}" />
                                                            </Grid>
                                                        </Button>
                                                        <Button Grid.Column="1" Name="RemovePassiveBtn" Tag="{Binding}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{StaticResource TextMutedBrush}"
                                                                FontSize="{DynamicResource FontSize11}" Padding="4,0"
                                                                Cursor="Hand" Content="×" Opacity="0.5"
                                                                ToolTip.Tip="Remove passive" />
                                                    </Grid>
                                                    <StackPanel IsVisible="{Binding IsExpanded}" Spacing="6" Margin="14,4,0,0" ClipToBounds="False">
                                                        <!-- Properties toggle chips -->
                                                        <ctrl:ToggleChipsEditor Text="{Binding EditProperties}"
                                                                                Options="{x:Static vm:PassiveVM.PassivePropertyOptions}" />
                                                        <!-- Permanent boosts section -->
                                                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="4" Padding="8,6"
                                                                BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="2,0,0,0">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding LblPermanentBoosts, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" />
                                                                <ctrl:BoostBlocksEditor Text="{Binding EditBoosts}" />
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Trigger-based section -->
                                                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="4" Padding="8,6"
                                                                BorderBrush="{DynamicResource WarningBrush}" BorderThickness="2,0,0,0"
                                                                ClipToBounds="False">
                                                            <StackPanel Spacing="3" ClipToBounds="False">
                                                                <TextBlock Text="{Binding LblTriggerCondAction, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                                                                <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto" ClipToBounds="False">
                                                                    <TextBlock Text="{Binding LblWhen, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                                    <ctrl:ChecklistPickerChip Grid.Column="1" Text="{Binding EditStatsFunctorContext}"
                                                                                          Options="{x:Static vm:PassiveVM.TriggerOptions}"
                                                                                          Labels="{x:Static vm:PassiveVM.TriggerLabels}"
                                                                                          Margin="0" />

                                                                    <TextBlock Grid.Row="1" Text="{Binding LblIf, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,3,0,0" />
                                                                    <ctrl:ConditionBlocksEditor Grid.Row="1" Grid.Column="1" Text="{Binding EditConditions}" Margin="0,3,0,0" />

                                                                    <TextBlock Grid.Row="2" Text="{Binding LblDo, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,3,0,0" />
                                                                    <ctrl:BoostBlocksEditor Grid.Row="2" Grid.Column="1" Text="{Binding EditStatsFunctors}" IsFunctorMode="True" Margin="0,3,0,0" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Context for boosts -->
                                                        <Grid ColumnDefinitions="60,*" IsVisible="{Binding EditBoostContext, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                            <TextBlock Text="{Binding LblContext, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize10}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                                            <TextBox Grid.Column="1" Text="{Binding EditBoostContext}" FontSize="{DynamicResource FontSize11}" Padding="6,3"
                                                                     Background="{StaticResource InputBgBrush}" CornerRadius="3" />
                                                        </Grid>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <!-- Create new artifact -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8" Padding="14,12" BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding LblCreateNewItem, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentLightBrush}" LetterSpacing="1" />

                                <!-- Based on -->
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding LblBasedOn, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayLabel}" FontSize="{DynamicResource FontSize11}"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                               ToolTip.Tip="{Binding EditUsingBase}" />
                                </StackPanel>

                                <!-- Name input -->
                                <TextBox Name="NewArtifactNameInput"
                                         Watermark="{Binding WmNewItemName, Source={x:Static loc:Loc.Instance}}"
                                         FontSize="{DynamicResource FontSize12}" Padding="8,6"
                                         Background="{StaticResource InputBgBrush}" CornerRadius="4" />

                                <!-- Create button -->
                                <Button Background="{StaticResource AccentBrush}" Foreground="White"
                                        FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                                        Padding="16,8" CornerRadius="6" Cursor="Hand"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Name="CreateNewArtifactBtn">
                                    <TextBlock Text="{Binding BtnCreateArtifact, Source={x:Static loc:Loc.Instance}}" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Save / Reset -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Center" Margin="0,8,0,12"
                            IsVisible="{Binding IsArtifactSelected}">
                    <Button Command="{Binding SaveArtifactCommand}"
                            Background="{DynamicResource SuccessBrush}" Foreground="White"
                            FontSize="{DynamicResource FontSize14}" FontWeight="Bold"
                            Padding="30,10" CornerRadius="8" Cursor="Hand">
                        <TextBlock Text="{Binding BtnSave, Source={x:Static loc:Loc.Instance}}" />
                    </Button>
                    <Border IsVisible="{ReflectionBinding DataContext.ShowSaveToast, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Background="#1A2ECC71" BorderBrush="#2ECC71" BorderThickness="1"
                            CornerRadius="6" Padding="12,6">
                        <TextBlock Text="{ReflectionBinding DataContext.SaveToastText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Foreground="#2ECC71" FontSize="{DynamicResource FontSize12}" FontWeight="SemiBold" />
                    </Border>
                    <Button Command="{Binding ResetArtifactCommand}"
                            Background="{DynamicResource ErrorBrush}" Foreground="White"
                            FontSize="{DynamicResource FontSize14}" FontWeight="Bold"
                            Padding="30,10" CornerRadius="8" Cursor="Hand"
                            BorderThickness="0">
                        <TextBlock Text="{Binding BtnReset, Source={x:Static loc:Loc.Instance}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="3" Width="6" Background="Transparent" ResizeDirection="Columns" />

        <!-- ═══════ RIGHT: PREVIEW / LOCA EDITOR ═══════ -->
        <Border Grid.Column="4" Background="{StaticResource PanelBgBrush}"
                CornerRadius="8" Padding="8" MinWidth="240"
                BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="1"
                Focusable="True">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0"
                           Text="{Binding ConstructorPreviewTitle, Source={x:Static loc:Loc.Instance}}"
                           FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,6" LetterSpacing="2" />

                <!-- Language selector + code/preview toggle -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="8,0,8,6">
                    <ctrl:TumblerChipEditor Name="LocaLangSelector" HorizontalAlignment="Left" />
                    <Button Grid.Column="2" Name="ToggleCodeViewBtn"
                            FontSize="{DynamicResource FontSize14}"
                            Padding="8,4" CornerRadius="6" Cursor="Hand"
                            Background="{StaticResource CardBgBrush}"
                            Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}"
                            ToolTip.Tip="{Binding TipToggleCodePreview, Source={x:Static loc:Loc.Instance}}" />
                </Grid>

                <!-- Loca warning -->
                <Border Grid.Row="2"
                        IsVisible="{Binding LocaWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#33F39C12" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8,4" Margin="8,0,8,4">
                    <TextBlock Text="{Binding LocaWarning}" FontSize="{DynamicResource FontSize11}" Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap" />
                </Border>

                <!-- BB-code toolbar -->
                <WrapPanel Grid.Row="3" Name="BbToolbar" Margin="8,0,8,6">
                    <Button Content="B" Tag="b" Classes="BbBtn" FontSize="{DynamicResource FontSize11}" FontWeight="Bold"
                            Padding="6,3" Margin="2" CornerRadius="4" MinWidth="28"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipBold, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="I" Tag="i" Classes="BbBtn" FontSize="{DynamicResource FontSize11}" FontStyle="Italic"
                            Padding="6,3" Margin="2" CornerRadius="4" MinWidth="28"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipItalic, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="Status" Tag="status" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{DynamicResource ErrorBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipStatus, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="Tooltip" Tag="tip" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{DynamicResource InfoBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipTooltip, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="Spell" Tag="spell" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{DynamicResource RarityVeryRareBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipSpell, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="Passive" Tag="passive" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{DynamicResource SuccessBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipPassive, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="Resource" Tag="resource" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="#F1C40F"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipResource, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="[p]" Tag="p" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{DynamicResource WarningBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipParam, Source={x:Static loc:Loc.Instance}}" />
                    <Button Content="BR" Tag="br" Classes="BbBtn" FontSize="{DynamicResource FontSize10}"
                            Padding="6,3" Margin="2" CornerRadius="4"
                            Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextMutedBrush}"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="{Binding BbTipLineBreak, Source={x:Static loc:Loc.Instance}}" />
                </WrapPanel>

                <!-- Tooltip preview (inline editable) -->
                <ScrollViewer Grid.Row="4" IsVisible="{Binding IsArtifactSelected}" Margin="4">
                    <Border Background="{DynamicResource AppBgBrush}" CornerRadius="10"
                            BorderBrush="{Binding RarityColor}"
                            BorderThickness="3,0,0,0"
                            VerticalAlignment="Top"
                            DataContext="{Binding SelectedArtifact}">
                        <StackPanel>
                            <!-- Top: Icon (right) + Name (left) + rarity gradient -->
                            <Border Background="{Binding RarityGradient}" CornerRadius="10,0,0,0">
                                <Grid ColumnDefinitions="*,Auto" Margin="18,14,14,0">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                        <!-- Name (editable) -->
                                        <TextBox Name="LocaDisplayName"
                                                 Text="{Binding EditDisplayName}" Watermark="{Binding WmItemName, Source={x:Static loc:Loc.Instance}}"
                                                 FontSize="{DynamicResource FontSize18}" FontWeight="Bold"
                                                 Foreground="{Binding RarityColor}"
                                                 Background="Transparent" BorderThickness="0"
                                                 Padding="0" TextWrapping="Wrap" />
                                        <!-- Rarity + Type -->
                                        <TextBlock Text="{Binding PreviewSubtitle}" FontSize="{DynamicResource FontSize12}"
                                                   Foreground="{Binding RarityColor}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <!-- Icon (large, pushed into top-right corner) -->
                                    <Border Grid.Column="1" Width="200" Height="200"
                                            ClipToBounds="True"
                                            Background="Transparent"
                                            Margin="0,-14,-14,0"
                                            VerticalAlignment="Top"
                                            IsVisible="{Binding HasIcon}">
                                        <Image Source="{Binding IconBitmap}" Stretch="Uniform" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="12,10" />

                            <!-- Boosts (display) -->
                            <TextBlock Text="{Binding PreviewBoostsText}" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"
                                       Margin="16,0,16,4" IsVisible="{Binding HasBoosts}" />

                            <!-- MainHand boosts -->
                            <TextBlock Text="{Binding PreviewMainHandText}" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"
                                       Margin="16,0,16,4" IsVisible="{Binding HasMainHandBoosts}" />

                            <!-- OffHand boosts -->
                            <TextBlock Text="{Binding PreviewOffHandText}" FontSize="{DynamicResource FontSize12}"
                                       Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"
                                       Margin="16,0,16,4" IsVisible="{Binding HasOffHandBoosts}" />

                            <!-- Passives: each name + description editable -->
                            <ItemsControl ItemsSource="{Binding PassiveVMs}"
                                          Margin="16,0,16,4"
                                          IsVisible="{Binding HasPassives}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PassiveVM">
                                        <Border Margin="0,0,0,6" CornerRadius="6" Padding="10,6"
                                                IsVisible="{Binding HasVisibleLoca}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#20C8A882" Offset="0" />
                                                    <GradientStop Color="#10A08060" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        <StackPanel>
                                            <TextBox Text="{Binding EditDisplayName}"
                                                     Watermark="{Binding WmPassiveName, Source={x:Static loc:Loc.Instance}}"
                                                     FontSize="{DynamicResource FontSize12}" FontWeight="Bold"
                                                     Foreground="{DynamicResource GoldBrush}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Padding="0" Margin="0" MinHeight="0" />
                                            <!-- Passive desc: preview = rendered BB-code with params -->
                                            <ctrl:BbCodeTextBlock BbText="{Binding EditDescription}"
                                                     BbParams="{Binding EditDescriptionParams}"
                                                     FontSize="{DynamicResource FontSize12}"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                     TextWrapping="Wrap"
                                                     IsVisible="{ReflectionBinding DataContext.IsPreviewView, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <!-- Passive desc: code mode = raw TextBox -->
                                            <TextBox Text="{Binding EditDescription}"
                                                     Watermark="{Binding WmPassiveDesc, Source={x:Static loc:Loc.Instance}}"
                                                     FontSize="{DynamicResource FontSize12}"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                     Background="Transparent" BorderThickness="0"
                                                     Padding="0" TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     IsVisible="{ReflectionBinding DataContext.IsCodeView, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <!-- DescriptionParams chips -->
                                            <ctrl:ChipListEditor Text="{Binding EditDescriptionParams}"
                                                     ChipColor="#E67E22"
                                                     IsVisible="{ReflectionBinding DataContext.IsCodeView, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="12,6"
                                    IsVisible="{Binding HasDescription}" />

                            <!-- Description / lore -->
                            <ctrl:BbCodeTextBlock BbText="{Binding EditDescription}"
                                     FontSize="{DynamicResource FontSize12}" FontStyle="Italic"
                                     Foreground="{DynamicResource TextMutedBrush}"
                                     TextWrapping="Wrap"
                                     Margin="16,0,16,8"
                                     IsVisible="{ReflectionBinding DataContext.IsPreviewView, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <TextBox Name="LocaDescription"
                                     Text="{Binding EditDescription}"
                                     Watermark="{Binding WmDescriptionLore, Source={x:Static loc:Loc.Instance}}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     MinHeight="40" FontSize="{DynamicResource FontSize11}"
                                     Foreground="{DynamicResource TextMutedBrush}"
                                     Background="{DynamicResource InputBgBrush}"
                                     CornerRadius="4" Padding="8,4"
                                     Margin="16,0,16,8"
                                     IsVisible="{ReflectionBinding DataContext.IsCodeView, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                            <!-- Price (gold value) -->
                            <Grid ColumnDefinitions="Auto,Auto,*" Margin="16,4,16,8">
                                <TextBlock Grid.Column="0" Text="&#x1FA99;"
                                           FontSize="{DynamicResource FontSize14}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding EditValueOverride}"
                                         FontSize="{DynamicResource FontSize13}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource GoldBrush}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="0" MinWidth="60"
                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="gp"
                                           FontSize="{DynamicResource FontSize11}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Margin="2,0,0,0" />
                            </Grid>

                            <!-- Bottom rarity glow -->
                            <Border Height="24" CornerRadius="0,0,10,10"
                                    Background="{Binding RarityGlowBottom}" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
    <!-- Icon browser popup overlay -->
    <Border IsVisible="{Binding IconBrowser.IsOpen}"
            Background="#CC000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="{StaticResource PanelBgBrush}"
                CornerRadius="14"
                Margin="40,20"
                MaxWidth="900" MaxHeight="700"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,Auto,*">

                <!-- Header bar with separator -->
                <Border Grid.Row="0" Padding="20,14" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Current icon mini -->
                        <Border Width="40" Height="40" CornerRadius="6" ClipToBounds="True">
                            <Image Source="{Binding IconBrowser.CurrentIconBitmap}" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding LblChooseIcon, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize16}" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding IconBrowser.CurrentIconName, FallbackValue='No icon selected'}"
                                       FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Command="{Binding IconBrowser.CloseCommand}"
                                Background="{StaticResource CardBgBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="{DynamicResource FontSize12}" Padding="10,6" CornerRadius="6"
                                BorderThickness="0" Cursor="Hand"
                                Content="{Binding BtnClose, Source={x:Static loc:Loc.Instance}}" />
                    </Grid>
                </Border>

                <!-- Atlas selector + Search + count -->
                <Border Grid.Row="1" Padding="16,8,16,8" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding IconBrowser.Tabs}"
                                  SelectedItem="{Binding IconBrowser.SelectedTab}"
                                  FontSize="{DynamicResource FontSize11}" Padding="8,6" MinWidth="140"
                                  CornerRadius="8" Margin="0,0,8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="vm:AtlasTabVM">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Grid.Column="1"
                                 Text="{Binding IconBrowser.SearchText}"
                                 Watermark="{Binding WmSearchIcons, Source={x:Static loc:Loc.Instance}}"
                                 FontSize="{DynamicResource FontSize12}" Padding="10,8" CornerRadius="8"
                                 Background="{StaticResource InputBgBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding IconBrowser.IconCount, StringFormat='{}{0} icons'}"
                                   FontSize="{DynamicResource FontSize11}" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <Border Grid.Row="2" IsVisible="{Binding IconBrowser.IsLoading}"
                        Padding="16,12">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding LblLoadingIcons, Source={x:Static loc:Loc.Instance}}" FontSize="{DynamicResource FontSize11}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Icon grid -->
                <ListBox Grid.Row="3"
                         ItemsSource="{Binding IconBrowser.DisplayIcons}"
                         Background="Transparent" BorderThickness="0"
                         Padding="12,4"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="110" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:IconEntryVM">
                            <Button Background="Transparent" BorderThickness="0"
                                    Padding="2" Margin="1" Cursor="Hand"
                                    ToolTip.Tip="{Binding Name}"
                                    Name="IconGridBtn" Tag="{Binding}">
                                <StackPanel Width="100" Spacing="3">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                           Width="72" Height="72" />
                                    <Border Height="16" ClipToBounds="True">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="{DynamicResource FontSize10}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Border>
    </Panel>
</UserControl>
