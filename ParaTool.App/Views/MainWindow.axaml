<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ParaTool.App.ViewModels"
        xmlns:v="using:ParaTool.App.Views"
        xmlns:loc="using:ParaTool.App.Localization"
        xmlns:ctrl="using:ParaTool.App.Controls"
        x:Class="ParaTool.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app_icon.png"
        Title="ParaTool"
        Width="1610" Height="978"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top bar: update button + language selector -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="8,8,16,4">
            <!-- Update button (left) -->
            <ctrl:UpdateButton Grid.Column="0"
                               State="{Binding UpdateState}"
                               UpdateVersion="{Binding UpdateVersion}"
                               Progress="{Binding UpdateProgress}"
                               ErrorMessage="{Binding UpdateError}"
                               Tapped="OnUpdateButtonTapped" />

            <!-- Language selector (right) -->
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      FontSize="{DynamicResource FontSize12}"
                      MinWidth="100">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="loc:LangInfo">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- View content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:StartupViewModel">
                    <v:StartupView />
                </DataTemplate>
                <DataTemplate DataType="vm:ScanningViewModel">
                    <v:ScanningView />
                </DataTemplate>
                <DataTemplate DataType="vm:ItemEditorViewModel">
                    <v:ItemEditorView />
                </DataTemplate>
                <DataTemplate DataType="vm:ConstructorViewModel">
                    <v:ConstructorView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

        <!-- Bottom tab bar (only visible after scan completes) -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowTabBar}"
                Background="{StaticResource PanelBgBrush}"
                CornerRadius="8,8,0,0"
                Padding="0,4,0,4"
                BorderBrush="{DynamicResource BorderPanelBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,*">
                <!-- Version (left) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding AppVersion}"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="12,0,0,0"
                           FontSize="{DynamicResource FontSize10}"
                           Foreground="{StaticResource TextMutedBrush}"
                           Opacity="0.5"
                           IsHitTestVisible="False" />
                <!-- Tabs (center) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="4">
                    <!-- PATCHER tab -->
                    <Button Command="{Binding SwitchToPatcherCommand}"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="6" Padding="0" Cursor="Hand">
                        <Border Padding="36,10" CornerRadius="6"
                                BorderThickness="0,3,0,0"
                                BorderBrush="{Binding PatcherTabBrush}">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Name="PinPatcherIcon" Text="📌" FontSize="9" Opacity="0.25"
                                           VerticalAlignment="Top" Margin="0,-2,4,0" />
                                <TextBlock Grid.Column="1" Text="{Binding TabPatcher, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize14}" FontWeight="Bold"
                                           Foreground="{Binding PatcherTabForeground}"
                                           LetterSpacing="1" />
                            </Grid>
                        </Border>
                    </Button>

                    <!-- CONSTRUCTOR tab -->
                    <Button Command="{Binding SwitchToConstructorCommand}"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="6" Padding="0" Cursor="Hand">
                        <Border Padding="36,10" CornerRadius="6"
                                BorderThickness="0,3,0,0"
                                BorderBrush="{Binding ConstructorTabBrush}">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Name="PinConstructorIcon" Text="📌" FontSize="9" Opacity="0.25"
                                           VerticalAlignment="Top" Margin="0,-2,4,0" />
                                <TextBlock Grid.Column="1" Text="{Binding TabConstructor, Source={x:Static loc:Loc.Instance}}"
                                           FontSize="{DynamicResource FontSize14}" FontWeight="Bold"
                                           Foreground="{Binding ConstructorTabForeground}"
                                           LetterSpacing="1" />
                            </Grid>
                        </Border>
                    </Button>
                </StackPanel>

                <!-- Settings (right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Spacing="6" Margin="0,0,12,0">
                    <!-- Font size -->
                    <ComboBox Name="FontSizeSelector"
                              FontSize="11" Padding="6,3" MinWidth="65"
                              ToolTip.Tip="{Binding TipFontSize, Source={x:Static loc:Loc.Instance}}">
                        <ComboBoxItem Content="A  -30%" />
                        <ComboBoxItem Content="A  0%" />
                        <ComboBoxItem Content="A  +50%" />
                    </ComboBox>

                    <!-- Fullscreen toggle -->
                    <Button Name="FullscreenBtn" Click="OnFullscreenClick"
                            Background="Transparent" BorderThickness="0"
                            Padding="6,3" Cursor="Hand" FontSize="16"
                            ToolTip.Tip="Fullscreen (F11)">
                        <TextBlock Name="FullscreenIcon" Text="&#x26F6;" />
                    </Button>

                    <!-- Theme -->
                    <ComboBox Name="ThemeSelector"
                              FontSize="11" Padding="6,3" MinWidth="130"
                              ToolTip.Tip="{Binding TipColorTheme, Source={x:Static loc:Loc.Instance}}">
                        <ComboBoxItem Content="🟣 Paramonov" />
                        <ComboBoxItem Content="⚪ Light" />
                        <ComboBoxItem Content="🔴 Dota 2" />
                        <ComboBoxItem Content="🟡 Cyberpunk" />
                        <ComboBoxItem Content="⚔️ WoW" />
                        <ComboBoxItem Content="❄️ Nord" />
                        <ComboBoxItem Content="💜 Synthwave" />
                        <ComboBoxItem Content="⚔️ BG3" />
                        <ComboBoxItem Content="🎀 Pinky" />
                        <ComboBoxItem Content="💻 Hacker" />
                        <ComboBoxItem Content="🤡 Clown" />
                        <ComboBoxItem Content="🏛️ Gov" />
                        <ComboBoxItem Content="🌿 Nature" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
