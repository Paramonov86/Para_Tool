<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ParaTool.App.ViewModels"
        xmlns:v="using:ParaTool.App.Views"
        xmlns:loc="using:ParaTool.App.Localization"
        xmlns:ctrl="using:ParaTool.App.Controls"
        x:Class="ParaTool.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app_icon.png"
        Title="ParaTool"
        Width="1400" Height="850"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top bar: update button + language selector -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="8,8,16,4">
            <!-- Update button (left) -->
            <ctrl:UpdateButton Grid.Column="0"
                               State="{Binding UpdateState}"
                               UpdateVersion="{Binding UpdateVersion}"
                               Progress="{Binding UpdateProgress}"
                               ErrorMessage="{Binding UpdateError}"
                               Tapped="OnUpdateButtonTapped" />

            <!-- Language selector (right) -->
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      FontSize="12"
                      MinWidth="100">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="loc:LangInfo">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- View content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:StartupViewModel">
                    <v:StartupView />
                </DataTemplate>
                <DataTemplate DataType="vm:ScanningViewModel">
                    <v:ScanningView />
                </DataTemplate>
                <DataTemplate DataType="vm:ItemEditorViewModel">
                    <v:ItemEditorView />
                </DataTemplate>
                <DataTemplate DataType="vm:ConstructorViewModel">
                    <v:ConstructorView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

        <!-- Bottom tab bar (only visible after scan completes) -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowTabBar}"
                Background="{StaticResource PanelBgBrush}"
                CornerRadius="8,8,0,0"
                Padding="0,4,0,4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="4">
                <!-- PATCHER tab -->
                <Button Command="{Binding SwitchToPatcherCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="0"
                        Cursor="Hand">
                    <Border Padding="36,10"
                            CornerRadius="6"
                            BorderThickness="0,3,0,0"
                            BorderBrush="{Binding PatcherTabBrush}">
                        <TextBlock Text="{Binding TabPatcher, Source={x:Static loc:Loc.Instance}}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding PatcherTabForeground}"
                                   LetterSpacing="1" />
                    </Border>
                </Button>

                <!-- CONSTRUCTOR tab -->
                <Button Command="{Binding SwitchToConstructorCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="0"
                        Cursor="Hand">
                    <Border Padding="36,10"
                            CornerRadius="6"
                            BorderThickness="0,3,0,0"
                            BorderBrush="{Binding ConstructorTabBrush}">
                        <TextBlock Text="{Binding TabConstructor, Source={x:Static loc:Loc.Instance}}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{Binding ConstructorTabForeground}"
                                   LetterSpacing="1" />
                    </Border>
                </Button>
            </StackPanel>
        </Border>

        <!-- Version overlay -->
        <TextBlock Grid.Row="1"
                   Text="{Binding AppVersion}"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="8,0,0,4"
                   FontSize="10"
                   Foreground="{StaticResource TextMutedBrush}"
                   Opacity="0.5"
                   IsHitTestVisible="False" />
    </Grid>
</Window>
