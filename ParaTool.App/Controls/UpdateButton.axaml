<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ParaTool.App.Controls.UpdateButton"
             Width="32" Height="32">

    <UserControl.Styles>
        <Style Selector="Path.spinning">
            <Setter Property="RenderTransform">
                <RotateTransform />
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Button Name="UpdateBtn"
            Background="Transparent"
            BorderThickness="0"
            Padding="4"
            Width="32" Height="32"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Cursor="Hand">
        <Panel>
            <!-- Refresh icon -->
            <Path Name="RefreshIcon"
                  Width="18" Height="18"
                  Stretch="Uniform"
                  RenderTransformOrigin="50%,50%"
                  Data="M17.65 6.35A7.958 7.958 0 0 0 12 4C7.58 4 4.01 7.58 4.01 12S7.58 20 12 20c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />

            <!-- Version badge -->
            <Border Name="VersionBadge"
                    IsVisible="False"
                    Background="#27AE60"
                    CornerRadius="6"
                    Padding="3,1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-4,-4,0">
                <TextBlock Name="VersionText"
                           FontSize="8"
                           FontWeight="Bold"
                           Foreground="White" />
            </Border>

            <!-- Progress text overlay -->
            <TextBlock Name="ProgressText"
                       IsVisible="False"
                       FontSize="8"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Panel>
    </Button>
</UserControl>
