-- ========== PIRATE GRENADE MARKER SYSTEM ==========

-- Check if grenade slot N is the next free slot for grenade type
-- Used in SpellProperties IF() to apply correct marker
function NextPirateGrenadeSlot(grenadeNum, slotNum)
    local breast = GetItemInEquipmentSlot(EquipmentSlot.Breast, context.Source)
    for i = 1, slotNum - 1 do
        if not HasStatus('AMP_PIRATE_G' .. string.format('%02d', grenadeNum) .. '_USED_' .. i, breast).Result then
            return ConditionResult(false)
        end
    end
    return ~HasStatus('AMP_PIRATE_G' .. string.format('%02d', grenadeNum) .. '_USED_' .. slotNum, breast)
end

-- Check if character has any grenades left (any slot free)
-- Used in RequirementConditions to disable spell when all used
function PirateGrenadeAvailable(grenadeNum, maxUses)
    local breast = GetItemInEquipmentSlot(EquipmentSlot.Breast, context.Source)
    for i = 1, maxUses do
        if not HasStatus('AMP_PIRATE_G' .. string.format('%02d', grenadeNum) .. '_USED_' .. i, breast).Result then
            return ConditionResult(true)
        end
    end
    return ConditionResult(false)
end

-- ========== GUIDING BOLT SPELL CHECK ==========

-- ========== MELEE MAIN HAND ATTACK CHECK ==========

-- Matches Target_MainHandAttack and all its children/variants
-- Used for Reach shard (AMP_SHARD_CHAR_REACH) to increase melee weapon reach
function AMP_IsMeleeMainHandAttack()
    return IsSpellIdOrChild('Target_MainHandAttack')
    | IsSpellIdOrChild('Target_OffhandAttack')
end

-- Check if spell is Guiding Bolt or any of its variants
-- Used for AMP_Stardruid_Helmet - restores Cosmic Omen on cast
-- Includes: base Guiding Bolt, StarMap variant, Free variant
function IsGuidingBolt()
    return IsSpellIdOrChild('Projectile_GuidingBolt')
    | IsSpellIdOrChild('Projectile_GuidingBolt_StarMap')
    | IsSpellIdOrChild('Projectile_GuidingBolt_Free')
end

-- Check if spell is Inflict Wounds or any of its variants
-- Used for Zinghi's Tunic (MAG_Armour_C_4) - Necro Nuke rework
function IsNecroNuke()
    return IsSpellIdOrChild('Target_InflictWounds')
    | IsSpellIdOrChild('AMP_Target_InflictWounds')
end

-- Check if entity is resistant to Necrotic damage
-- Used for AMP_Target_InflictWounds self-damage condition
function IsResistantToNecroticDamage(entity)
    local entity = entity or context.Target
    return IsResistantToDamageType(DamageType.Necrotic, entity)
end

-- ========== ABILITY COMPARISON CHECKS ==========

-- Check if entity's Wisdom is greater than their Strength
-- Used for AMP_CaioShin_WisdomCrit_Passive - restore reaction on crit when Wisdom > Strength
function IsWisdomGreaterThanStrength(entity)
    entity = entity or context.Source
    return ConditionResult(entity.Wisdom > entity.Strength)
end

-- Check if entity's Charisma is greater than a given value
-- Usage: AMP_CharismaGreaterThan(22, context.Source)
function AMP_CharismaGreaterThan(value, entity)
    entity = entity or context.Source
    return ConditionResult(entity.Charisma > value)
end

-- ========== CHILL TOUCH SPELL CHECK ==========

-- Check if spell is Chill Touch or any of its variants
-- Used for Armour of the Sage Revenant toggle - removes Action Point cost
function IsChillTouch()
    return IsSpellIdOrChild('Target_ChillTouch')
end

-- ========== SELF-INTERACTION CHECKS ==========
-- Problem: Self() checks context.Source == context.Target.
-- Self(context.Source) is IDENTICAL to Self() because entity2 defaults to context.Target.
-- These helpers have explicit names so you never confuse which entity is checked.

-- For OnDamaged passive: "damage came from another entity, not myself"
-- Source = attacker, Target = victim (passive owner)
-- Also validates Source.IsValid — surface/environmental damage may have no valid Source
function IsDamagedByOther()
    return ConditionResult(context.Source.IsValid and context.Source ~= context.Target)
end

-- For OnDamaged passive: "I damaged myself" (self-harm, own surface, etc.)
function IsSelfDamage()
    return ConditionResult(context.Source.IsValid and context.Source == context.Target)
end

-- For OnDamage passive: "I'm attacking someone else, not myself"
-- Source = attacker (passive owner), Target = victim
function IsAttackingOther()
    return ConditionResult(context.Target.IsValid and context.Source ~= context.Target)
end

-- For OnHeal passive: "I'm healing someone else, not myself"
-- Source = healer (passive owner), Target = heal recipient
function IsHealingOther()
    return ConditionResult(context.Target.IsValid and context.Source ~= context.Target)
end

-- For OnHeal passive: "I'm healing myself"
function IsSelfHeal()
    return ConditionResult(context.Source.IsValid and context.Source == context.Target)
end

-- For OnStatusApplied passive: "status was applied by a different entity"
-- Source = who applied status, Target = who received status
function IsStatusFromOther()
    return ConditionResult(context.Source.IsValid and context.Source ~= context.Target)
end

-- For OnStatusApplied passive: "I applied this status to myself"
function IsStatusFromSelf()
    return ConditionResult(context.Source.IsValid and context.Source == context.Target)
end

-- For InterruptData: "observer is the one who attacked/cast"
-- Observer = interrupt owner, Source = attacker/caster, Target = victim
function IsObserverAttacker()
    return Self(context.Source, context.Observer)
end

-- For InterruptData: "observer is the one being attacked/targeted"
function IsObserverVictim()
    return Self(context.Target, context.Observer)
end

-- ========== SLOW STATUS CHECK ==========

-- Check if entity has any variant of Slow status
-- Used for N_Force necklace - crit threshold reduction while Slowed
-- Includes: base SLOW, TAD variants, Abjure Enemy, Gambler's modified
function IsSlow(entity)
    entity = entity or context.Target
    return HasStatus('SLOW', entity)
    | HasStatus('TAD_BLACK_HOLE_SLOW', entity)
    | HasStatus('ABJURE_ENEMY_SLOW', entity)
    | HasStatus('END_NETHERBRAIN_SLOW', entity)
    | HasStatus('AMP_GAMBLERS_SLOW_MODIFIED', entity)
end

-- ========== FORCE DAMAGE RESISTANCE CHECK ==========

-- Check if entity is resistant to Force damage
-- Used for N_Force Graviton passive - self-slow bypass
function IsResistantToForceDamage(entity)
    local entity = entity or context.Source
    return IsResistantToDamageType(DamageType.Force, entity)
end

-- Check if entity is immune to Force damage
function IsImmuneToForceDamage(entity)
    local entity = entity or context.Source
    return IsImmuneToDamageType(DamageType.Force, entity)
end

-- ========== NECROMANCY CANTRIP CHECK ==========

-- Check if spell is a Necromancy school cantrip
-- Used for Reaper passive - universal +1 target for all necromancy cantrips
-- Replaces hardcoded list (ChillTouch, BurstingSinew, TollTheDead) with universal condition
function IsNecromancyCantrip()
    return IsCantrip() & IsSpellOfSchool(SpellSchool.Necromancy)
end

-- ========== SHIELD SAVING THROW FROM WEAPON ATTACK ==========

-- ========== NATURE ENSNARE STATUS CHECK ==========

-- Check if target has any vine/web/ensnare status
-- Used for Gwaeron's Edge (Kyzr commission) - bonus poison damage + crit threshold reduction
-- Includes: Ensnared (vines), Ensnaring Strike, Nature's Wrath, Web
function IsNatureEnsnare(entity)
    entity = entity or context.Target
    return HasStatus('ENSNARED_VINES', entity)
    | HasStatus('ENSNARED', entity)
    | HasStatus('NATURES_WRATH', entity)
    | HasStatus('ENSNARING_STRIKE_2', entity)
    | HasStatus('ENSNARING_STRIKE', entity)
    | HasStatus('WEB', entity)
end

-- ========== EARTH MYRMIDON WILDSHAPE CHECK ==========

-- Check if spell is Earth Myrmidon Wild Shape or its combat variant
-- Used for Chauntean Boots of Jubilation legendary - free Earth Myrmidon entry
function IsEarthMyrmidonWildShape()
    return IsSpellIdOrChild('Shout_WildShape_Myrmidon_Earth')
    | IsSpellIdOrChild('Shout_WildShape_Combat_Myrmidon_Earth')
end

-- ========== PSYCHIC DOMINANCE SPELL CHECK ==========

-- Check if spell is a psychic dominance spell (mind control themed)
-- Used for N_Psychic_Dominance - makes these spells free to cast
-- Includes: Sleep, Hideous Laughter, Crown of Madness, Hypnotic Pattern,
--           Confusion, Dominate Person, Dissonant Whispers
function IsPsychicDominance()
    return IsSpellIdOrChild('Target_Sleep')
    | IsSpellIdOrChild('Target_HideousLaughter')
    | IsSpellIdOrChild('Target_CrownOfMadness')
    | IsSpellIdOrChild('Target_HypnoticPattern')
    | IsSpellIdOrChild('Target_Confusion')
    | IsSpellIdOrChild('Target_DominatePerson')
    | IsSpellIdOrChild('Target_DissonantWhispers')
end

function IsWizard(entity)
    entity = entity or context.Source
    return Tagged('WIZARD', entity)
end

function IsWizardIceStorm(entity)
    entity = entity or context.Source
    return Tagged('WIZARD', entity) & IsSpellIdOrChild('Target_IceStorm')
end

function IsBurningAgony()
    return IsSpellIdOrChild('Projectile_Fireball') |
           IsSpellIdOrChild('Target_FlameStrike')
end

